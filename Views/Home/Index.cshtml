@* ============================================================================
   PÁGINA INICIAL - LANDING PAGE DO WEBSITE FITCONTROL
   Esta vista apresenta a página inicial pública do website
   com secções de ginásios, benefícios, planos e testemunhos
   ============================================================================ *@

@* Modelo de dados da página inicial *@
@model TTFWebsite.Controllers.HomeViewModel

@* ============================================================================
   SECÇÃO HERO - ÁREA DE DESTAQUE PRINCIPAL
   Apresenta a mensagem principal e chamadas para ação
   ============================================================================ *@
<section id="home" class="hero">
    <div class="container">
        <div class="hero-content">
            @* Título principal *@
            <h1 class="hero-title">Encontra o Ginásio mais perto de ti</h1>
            
            @* Subtítulo com proposta de valor *@
            <p class="hero-subtitle">
                Treina onde e quando quiseres, com equipamentos premium, planos acessíveis e acompanhamento de verdade. 
                Sem fidelizações e mais de 24 clubes à tua disposição.
            </p>
            
            @* Botões de ação *@
            <div class="hero-actions">
                <a href="#gyms" class="btn-primary">ESCOLHE UM GINÁSIO PERTO DE TI</a>
                <a href="@Url.Action("Login", "Account")" class="btn-secondary">ÁREA DE MEMBROS</a>
                <a href="#plans" class="btn-outline">Quero ver Planos e Preços</a>
            </div>
        </div>
    </div>
</section>

@* ============================================================================
   SECÇÃO DE GINÁSIOS - LOCALIZAÇÕES DISPONÍVEIS
   Mostra a lista de ginásios e estatísticas da rede
   ============================================================================ *@
<section id="gyms" class="gyms-section">
    <div class="container">
        <h2 class="section-title">ESCOLHE UM GINÁSIO PERTO DE TI</h2>
        
        @* Grelha de cartões de ginásios *@
        <div class="gyms-grid">
            @foreach (var gym in Model.Gyms)
            {
                <div class="gym-card">
                    <h3>@gym.City</h3>
                </div>
            }
        </div>
        
        @* Estatísticas da rede FitControl *@
        <div class="stats">
            <div class="stat-item">
                <span class="stat-number">12</span>
                <span class="stat-label">anos</span>
            </div>
            <div class="stat-item">
                <span class="stat-number">24</span>
                <span class="stat-label">Clubes</span>
            </div>
            <div class="stat-item">
                <span class="stat-number">365</span>
                <span class="stat-label">dias por ano</span>
            </div>
        </div>
    </div>
</section>

@* ============================================================================
   SECÇÃO DE BENEFÍCIOS - VANTAGENS DO GINÁSIO
   Apresenta os principais benefícios de ser membro
   ============================================================================ *@
<section id="benefits" class="benefits-section">
    <div class="container">
        <h2 class="section-title">Benefícios reais para quem quer resultados</h2>
        
        @* Grelha de cartões de benefícios *@
        <div class="benefits-grid">
            @foreach (var benefit in Model.Benefits)
            {
                <div class="benefit-card">
                    @* Ícone do benefício *@
                    <div class="benefit-icon">
                        <span class="@benefit.IconClass"></span>
                    </div>
                    <h3>@benefit.Title</h3>
                    <p>@benefit.Description</p>
                </div>
            }
        </div>
    </div>
</section>

@* ============================================================================
   SECÇÃO DE TIPOS DE TREINO - PERFIS DE UTILIZADORES
   Mostra como o ginásio se adapta a diferentes necessidades
   ============================================================================ *@
<section class="training-types">
    <div class="container">
        <h2 class="section-title">Um Ginásio: Várias formas de treinar</h2>
        <p class="section-subtitle">Seja qual for o teu objetivo, os ginásios FitControl têm o plano certo para ti.</p>
        
        @* Grelha de tipos de treino *@
        <div class="training-grid">
            @* Profissionais ocupados *@
            <div class="training-card">
                <h3>Profissionais ocupados</h3>
                <p>Treina no teu horário. Quando podes e não quando o ginásio manda. Aberto das 6h às 24h, todos os dias. Sem desculpas!</p>
            </div>
            
            @* Famílias *@
            <div class="training-card">
                <h3>Famílias</h3>
                <p>Planos flexíveis para todos. Um só plano, várias soluções. Treinares com quem mais gostas nunca foi tão fácil. E económico!</p>
            </div>
            
            @* Mulheres *@
            <div class="training-card">
                <h3>Mulheres</h3>
                <p>Treina com conforto e privacidade. Lady Fitness é o teu espaço. Treina com confiança, no teu ritmo, com apoio técnico sempre que precisares.</p>
            </div>
            
            @* Iniciantes *@
            <div class="training-card">
                <h3>Iniciantes</h3>
                <p>Começa com apoio e um plano à tua medida. Com acompanhamento e sem pressões. Com estrutura, desde o primeiro dia.</p>
            </div>
        </div>
    </div>
</section>

@* ============================================================================
   SECÇÃO DE TESTEMUNHOS - OPINIÕES DE MEMBROS
   Apresenta comentários de membros satisfeitos
   ============================================================================ *@
<section class="testimonials-section">
    <div class="container">
        <h2 class="section-title">Histórias reais, Resultados reais</h2>
        
        @* Grelha de testemunhos *@
        <div class="testimonials-grid">
            @foreach (var testimonial in Model.Testimonials)
            {
                <div class="testimonial-card">
                    <p class="testimonial-text">"@testimonial.Comment"</p>
                    <p class="testimonial-author">@testimonial.Name</p>
                </div>
            }
        </div>
    </div>
</section>

@* ============================================================================
   SECÇÃO DE PLANOS - PREÇOS E SUBSCRIÇÕES
   Mostra os planos disponíveis com preços e funcionalidades
   ============================================================================ *@
<section id="plans" class="plans-section">
    <div class="container">
        <h2 class="section-title">Planos acessíveis e sem complicações</h2>
        <p class="section-subtitle">
            Treina com total liberdade. Sem fidelizações, nem complicações.<br>
            Escolhe o plano que se adapta ao teu ritmo, à tua vida e aos teus objetivos.
        </p>
        
        @* Grelha de cartões de planos *@
        <div class="plans-grid">
            @foreach (var plan in Model.Plans)
            {
                @* Adicionar classe "popular" se for o plano mais popular *@
                <div class="plan-card @(plan.IsPopular ? "popular" : "")">
                    @* Badge de plano popular *@
                    @if (plan.IsPopular)
                    {
                        <div class="popular-badge">Mais Popular</div>
                    }
                    
                    <h3>@plan.Name</h3>
                    
                    @* Preço do plano *@
                    <div class="plan-price">
                        <span class="price-amount">@plan.Price€</span>
                        <span class="price-period">/PAX</span>
                    </div>
                    
                    <p class="plan-description">@plan.Description</p>
                    
                    @* Lista de funcionalidades incluídas *@
                    <div class="plan-features">
                        <h4>O que está incluído:</h4>
                        <ul>
                            @foreach (var feature in plan.Features)
                            {
                                <li>@feature</li>
                            }
                        </ul>
                    </div>
                    
                    @* Nota sobre inscrição presencial *@
                    <p class="plan-note">Para te inscreveres, visita-nos presencialmente no ginásio.</p>
                </div>
            }
        </div>
        
        @* Rodapé da secção de planos *@
        <div class="plans-footer">
            <p>Não sabes qual plano escolher? Visita-nos no ginásio e descobre o que faz mais sentido para ti.</p>
            <a href="@Url.Action("Login", "Account")" class="btn-outline">Já és membro? Acede à tua área</a>
        </div>
    </div>
</section>

@* ============================================================================
   SECÇÃO DE CONTACTO - INFORMAÇÕES DE CONTACTO
   Mostra morada, email e acesso à área de membros
   ============================================================================ *@
<section id="contact" class="contact-section">
    <div class="container">
        <h2 class="section-title">Contacta-nos</h2>
        <p class="section-subtitle">Visita-nos presencialmente no ginásio para te inscreveres ou esclareceres dúvidas.</p>
        
        @* Grelha de informações de contacto *@
        <div class="contact-info">
            @* Morada *@
            <div class="contact-item">
                <h3>Morada</h3>
                <p>Rua Cipriano Dourado, 14B<br>1600-428 Lisboa</p>
            </div>
            
            @* Email *@
            <div class="contact-item">
                <h3>Email</h3>
                <p>geral@fitcontrol.pt</p>
            </div>
            
            @* Área de membros *@
            <div class="contact-item">
                <h3>Área de Membros</h3>
                <p>Já és membro? <a href="@Url.Action("Login", "Account")" class="btn-primary">Acede à tua área</a></p>
            </div>
        </div>
    </div>
</section>

@* ============================================================================
   ESTILOS CSS ESPECÍFICOS DA PÁGINA
   ============================================================================ *@
<style>
/* Nota sobre inscrição nos planos */
.plan-note {
    margin-top: 1rem;
    padding: 0.75rem;
    background: rgba(2, 172, 195, 0.1);
    border-radius: 6px;
    color: var(--text-secondary);
    font-size: 0.9rem;
    text-align: center;
}

/* Secção de contacto */
.contact-section {
    padding: 4rem 0;
    background: var(--bg-card);
}

/* Grelha de informações de contacto */
.contact-info {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
}

/* Cartão de contacto individual */
.contact-item {
    text-align: center;
    padding: 2rem;
    background: var(--bg-primary);
    border-radius: 12px;
    border: 1px solid var(--border);
}

/* Título do cartão de contacto */
.contact-item h3 {
    color: var(--accent);
    margin-bottom: 1rem;
    font-size: 1.2rem;
}

/* Texto do cartão de contacto */
.contact-item p {
    color: var(--text-secondary);
    line-height: 1.8;
}

/* Link dentro do cartão de contacto */
.contact-item a {
    margin-top: 1rem;
    display: inline-block;
}
</style>
