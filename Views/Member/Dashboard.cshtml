@* ============================================================================
   DASHBOARD DO MEMBRO - PAINEL PRINCIPAL DA ÁREA DE MEMBROS
   Esta vista apresenta um resumo de todas as informações relevantes
   para o membro: reservas, avaliações físicas e aulas disponíveis
   ============================================================================ *@

@* Modelo de dados do dashboard *@
@model TTFWebsite.Controllers.DashboardViewModel

@* Configurações da página *@
@{
    ViewData["Title"] = "Dashboard - Área de Membros";
    Layout = "~/Views/Shared/_MemberLayout.cshtml";
}

<div class="dashboard-container">
    @* Cabeçalho de boas-vindas *@
    <div class="dashboard-header">
        <h1>Bem-vindo, @Model.Profile.Name!</h1>
        <p class="subtitle">Ginásio: @Model.Profile.Gym | Membro desde @Model.Profile.MembershipStartDate.ToString("MMMM yyyy")</p>
    </div>

    @* Grelha de cartões do dashboard *@
    <div class="dashboard-grid">
        
        @* ================================================================
           CARTÃO DE PRÓXIMAS RESERVAS
           Mostra as próximas aulas reservadas pelo membro
           ================================================================ *@
        <div class="dashboard-card">
            <div class="card-header">
                <h2>Próximas Aulas</h2>
                <a href="@Url.Action("Classes", "Member")" class="btn-link">Ver todas</a>
            </div>
            
            @* Verificar se existem reservas *@
            @if (Model.UpcomingReservations.Any())
            {
                <div class="reservations-list">
                    @foreach (var reservation in Model.UpcomingReservations)
                    {
                        <div class="reservation-item">
                            @* Hora e data da reserva *@
                            <div class="reservation-time">
                                <span class="time">@reservation.ReservationDate.ToString("HH:mm")</span>
                                <span class="date">@reservation.ReservationDate.ToString("dd MMM")</span>
                            </div>
                            @* Detalhes da reserva *@
                            <div class="reservation-details">
                                <h3>Aula Reservada</h3>
                                <p>@reservation.ReservationDate.ToString("dddd, dd MMMM")</p>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                @* Estado vazio - sem reservas *@
                <p class="empty-state">Não tens aulas reservadas.</p>
                <a href="@Url.Action("Classes", "Member")" class="btn-primary">Reservar Aula</a>
            }
        </div>

        @* ================================================================
           CARTÃO DE AVALIAÇÃO FÍSICA
           Mostra a última avaliação física realizada
           ================================================================ *@
        <div class="dashboard-card">
            <div class="card-header">
                <h2>Avaliação Física</h2>
                <a href="@Url.Action("PhysicalAssessment", "Member")" class="btn-link">Ver histórico</a>
            </div>
            
            @* Verificar se existe avaliação *@
            @if (Model.RecentAssessment != null)
            {
                <div class="assessment-summary">
                    @* Data da última avaliação *@
                    <div class="assessment-date">
                        <span>Última avaliação: @Model.RecentAssessment.AssessmentDate.ToString("dd MMM yyyy")</span>
                    </div>
                    
                    @* Métricas da avaliação *@
                    <div class="assessment-metrics">
                        <div class="metric">
                            <span class="metric-label">Peso</span>
                            <span class="metric-value">@Model.RecentAssessment.Weight kg</span>
                        </div>
                        <div class="metric">
                            <span class="metric-label">Gordura Corporal</span>
                            <span class="metric-value">@Model.RecentAssessment.BodyFat%</span>
                        </div>
                        <div class="metric">
                            <span class="metric-label">Massa Muscular</span>
                            <span class="metric-value">@Model.RecentAssessment.MuscleMass kg</span>
                        </div>
                        <div class="metric">
                            <span class="metric-label">IMC</span>
                            <span class="metric-value">@Model.RecentAssessment.BMI</span>
                        </div>
                    </div>
                    
                    @* Nome do personal trainer *@
                    <div class="assessment-trainer">
                        <p><strong>Personal Trainer:</strong> @Model.RecentAssessment.TrainerName</p>
                    </div>
                </div>
            }
            else
            {
                @* Estado vazio - sem avaliações *@
                <p class="empty-state">Ainda não tens avaliações físicas registadas.</p>
            }
        </div>

        @* ================================================================
           CARTÃO DE AULAS DE HOJE
           Mostra as aulas disponíveis para o dia atual
           ================================================================ *@
        <div class="dashboard-card">
            <div class="card-header">
                <h2>Aulas de Hoje</h2>
                <a href="@Url.Action("Classes", "Member")" class="btn-link">Ver calendário</a>
            </div>
            
            @* Verificar se existem aulas hoje *@
            @if (Model.AvailableClassesToday.Any())
            {
                <div class="classes-list">
                    @foreach (var classItem in Model.AvailableClassesToday)
                    {
                        <div class="class-item">
                            @* Hora da aula *@
                            <div class="class-time">@classItem.StartTime.ToString("HH:mm")</div>
                            @* Informações da aula *@
                            <div class="class-info">
                                <h3>@classItem.Name</h3>
                                <p>@classItem.Instructor | @classItem.Room</p>
                                <span class="class-availability">@classItem.CurrentBookings/@classItem.MaxCapacity lugares</span>
                            </div>
                            @* Botão de reserva *@
                            <a href="@Url.Action("Classes", "Member")" class="btn-small">Reservar</a>
                        </div>
                    }
                </div>
            }
            else
            {
                @* Estado vazio - sem aulas hoje *@
                <p class="empty-state">Não há aulas disponíveis hoje.</p>
            }
        </div>

        @* ================================================================
           CARTÃO DE PERFIL DO MEMBRO
           Mostra um resumo das informações do membro
           ================================================================ *@
        <div class="dashboard-card">
            <div class="card-header">
                <h2>O Meu Perfil</h2>
                <a href="@Url.Action("Profile", "Member")" class="btn-link">Editar</a>
            </div>
            
            @* Resumo do perfil *@
            <div class="profile-summary">
                <div class="profile-item">
                    <span class="profile-label">Nº Membro:</span>
                    <span class="profile-value">@Model.Profile.MembershipNumber</span>
                </div>
                <div class="profile-item">
                    <span class="profile-label">Plano:</span>
                    <span class="profile-value">@Model.Profile.Plan</span>
                </div>
                <div class="profile-item">
                    <span class="profile-label">Ginásio:</span>
                    <span class="profile-value">@Model.Profile.Gym</span>
                </div>
                <div class="profile-item">
                    <span class="profile-label">Email:</span>
                    <span class="profile-value">@Model.Profile.Email</span>
                </div>
            </div>
        </div>
    </div>
</div>

@* ============================================================================
   ESTILOS CSS ESPECÍFICOS DO DASHBOARD
   ============================================================================ *@
<style>
/* Contentor principal do dashboard */
.dashboard-container {
    padding: 2rem;
    max-width: 1400px;
    margin: 0 auto;
}

/* Cabeçalho de boas-vindas */
.dashboard-header {
    margin-bottom: 2rem;
}

.dashboard-header h1 {
    font-size: 2.5rem;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
}

.subtitle {
    color: var(--text-secondary);
    font-size: 1.1rem;
}

/* Grelha de cartões responsiva */
.dashboard-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
}

/* Cartão do dashboard */
.dashboard-card {
    background: var(--bg-card);
    border-radius: 12px;
    padding: 1.5rem;
    border: 1px solid var(--border);
}

/* Cabeçalho do cartão */
.card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
}

.card-header h2 {
    font-size: 1.3rem;
    color: var(--text-primary);
}

/* Link de ação */
.btn-link {
    color: var(--accent);
    text-decoration: none;
    font-size: 0.9rem;
}

.btn-link:hover {
    text-decoration: underline;
}

/* Estado vazio */
.empty-state {
    color: var(--text-secondary);
    text-align: center;
    padding: 2rem 0;
}

/* Listas de reservas e aulas */
.reservations-list, .classes-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

/* Item de reserva/aula */
.reservation-item, .class-item {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    background: var(--bg-primary);
    border-radius: 8px;
    border: 1px solid var(--border);
}

/* Hora da reserva */
.reservation-time {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 60px;
}

.time {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--accent);
}

.date {
    font-size: 0.8rem;
    color: var(--text-secondary);
}

/* Detalhes da reserva */
.reservation-details h3 {
    font-size: 1rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
}

.reservation-details p {
    font-size: 0.9rem;
    color: var(--text-secondary);
}

/* Resumo da avaliação física */
.assessment-summary {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.assessment-date {
    color: var(--text-secondary);
    font-size: 0.9rem;
}

/* Grelha de métricas */
.assessment-metrics {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
}

/* Métrica individual */
.metric {
    display: flex;
    flex-direction: column;
    padding: 1rem;
    background: var(--bg-primary);
    border-radius: 8px;
}

.metric-label {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
}

.metric-value {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--accent);
}

/* Informação do personal trainer */
.assessment-trainer {
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    color: var(--text-secondary);
    font-size: 0.9rem;
}

/* Item de aula */
.class-item {
    align-items: center;
}

.class-time {
    font-size: 1.2rem;
    font-weight: bold;
    color: var(--accent);
    min-width: 60px;
}

/* Informações da aula */
.class-info {
    flex: 1;
}

.class-info h3 {
    font-size: 1rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
}

.class-info p {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
}

.class-availability {
    font-size: 0.8rem;
    color: var(--accent);
}

/* Botão pequeno */
.btn-small {
    padding: 0.5rem 1rem;
    background: var(--accent);
    color: white;
    text-decoration: none;
    border-radius: 6px;
    font-size: 0.9rem;
    white-space: nowrap;
}

.btn-small:hover {
    background: var(--accent-hover);
}

/* Resumo do perfil */
.profile-summary {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

/* Item do perfil */
.profile-item {
    display: flex;
    justify-content: space-between;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
}

.profile-item:last-child {
    border-bottom: none;
}

.profile-label {
    color: var(--text-secondary);
}

.profile-value {
    color: var(--text-primary);
    font-weight: 500;
}
</style>
