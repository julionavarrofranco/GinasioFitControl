@* ============================================================================
   LAYOUT PRINCIPAL - ESTRUTURA BASE PARA PÁGINAS PÚBLICAS
   Este ficheiro define a estrutura HTML comum a todas as páginas públicas
   do website FitControl (página inicial, login, etc.)
   ============================================================================ *@

<!DOCTYPE html>
<html lang="pt">
<head>
    @* Configuração de codificação de caracteres *@
    <meta charset="utf-8" />
    @* Configuração para responsividade em dispositivos móveis *@
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @* Título da página *@
    <title>FitControl - Treino, Transformação e Foco</title>
    @* Folha de estilos principal *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @* ================================================================
       CABEÇALHO - NAVEGAÇÃO PRINCIPAL
       Barra de navegação fixa no topo com menu e acesso à área de membros
       ================================================================ *@
    <header>
        <nav class="navbar">
            <div class="container">
                @* Logótipo com link para a página inicial *@
                <div class="logo">
                    <a href="@Url.Action("Index", "Home")" style="text-decoration: none; color: inherit;">
                        <h1>FitControl</h1>
                    </a>
                </div>
                
                @* Menu de navegação principal *@
                <ul class="nav-menu">
                    <li><a href="#home">Início</a></li>
                    <li><a href="#gyms">Ginásios</a></li>
                    <li><a href="#benefits">Benefícios</a></li>
                    <li><a href="#plans">Planos</a></li>
                    <li><a href="#contact">Contacto</a></li>
                </ul>
                
                @* Botão de acesso à área de membros *@
                <a href="@Url.Action("Login", "Account")" class="btn-primary">Área de Membros</a>
            </div>
        </nav>
    </header>

    @* ================================================================
       CONTEÚDO PRINCIPAL
       Área onde o conteúdo específico de cada página é renderizado
       ================================================================ *@
    <main>
        @RenderBody()
    </main>

    @* ================================================================
       RODAPÉ - INFORMAÇÕES E LINKS
       Área com links úteis, informações da empresa e contactos
       ================================================================ *@
    <footer class="footer">
        <div class="container">
            @* Grelha de secções do rodapé *@
            <div class="footer-content">
                @* Secção: O nosso clube *@
                <div class="footer-section">
                    <h3>O nosso clube</h3>
                    <ul>
                        <li><a href="#">Preços</a></li>
                        <li><a href="#">Descontos</a></li>
                        <li><a href="#">Personal Trainer</a></li>
                        <li><a href="#">Nutrição</a></li>
                        <li><a href="#">Parceiros</a></li>
                        <li><a href="#">Carreiras</a></li>
                        <li><a href="#">Plano de Saúde</a></li>
                    </ul>
                </div>
                
                @* Secção: Links legais e úteis *@
                <div class="footer-section">
                    <h3>Links</h3>
                    <ul>
                        <li><a href="#">Blog</a></li>
                        <li><a href="#">Termos e Condições</a></li>
                        <li><a href="#">Política de Privacidade</a></li>
                        <li><a href="#">Política de Cookies</a></li>
                        <li><a href="#">Regulamento Interno</a></li>
                        <li><a href="#">Livro de Reclamações</a></li>
                    </ul>
                </div>
                
                @* Secção: Contactos *@
                <div class="footer-section">
                    <h3>Contactos</h3>
                    <p>Rua Cipriano Dourado, 14B,<br>1600-428 Lisboa</p>
                    <p>geral@fitcontrol.pt</p>
                </div>
            </div>
            
            @* Barra inferior com copyright e redes sociais *@
            <div class="footer-bottom">
                <p>&copy; 2025 FitControl. Todos os direitos reservados.</p>
                @* Links para redes sociais *@
                <div class="social-links">
                    <a href="#">Instagram</a>
                    <a href="#">Facebook</a>
                    <a href="#">TikTok</a>
                    <a href="#">Youtube</a>
                </div>
            </div>
        </div>
    </footer>

    @* Script JavaScript principal *@
    <script src="~/js/site.js" asp-append-version="true"></script>
    @* Secção para scripts adicionais definidos nas vistas filhas *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
