@* ============================================================================
   PÁGINA DE ALTERAÇÃO DE PALAVRA-PASSE
   Esta vista permite aos membros autenticados alterarem a sua palavra-passe
   Exibida após o primeiro login ou quando o utilizador escolhe alterar
   ============================================================================ *@

@* Definir o modelo de dados esperado pela vista *@
@model TTFWebsite.Controllers.ChangePasswordViewModel

@* Configurações da página *@
@{
    ViewData["Title"] = "Alterar Palavra-passe";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* Contentor principal da página *@
<div class="login-container">
    @* Caixa do formulário *@
    <div class="login-box">
        @* Cabeçalho da página *@
        <div class="login-header">
            <h1>FitControl</h1>
            <h2>Alterar Palavra-passe</h2>
            <p>Por favor, altere a sua palavra-passe</p>
        </div>

        @* Mensagem de aviso quando é necessário alterar a palavra-passe (primeiro login) *@
        @if (TempData["NeedsPasswordChange"] != null && (bool)TempData["NeedsPasswordChange"])
        {
            <div class="alert alert-warning">
                @TempData["Message"]
            </div>
        }

        @* Mensagem de sucesso após alteração bem-sucedida *@
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }

        @* Formulário de alteração de palavra-passe *@
        <form asp-action="ChangePassword" method="post" class="login-form">
            @* Resumo de erros de validação *@
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @* Campo de palavra-passe atual *@
            <div class="form-group">
                <label asp-for="CurrentPassword">Palavra-passe Atual</label>
                <input asp-for="CurrentPassword" type="password" class="form-control" placeholder="••••••••" required />
                <span asp-validation-for="CurrentPassword" class="text-danger"></span>
            </div>

            @* Campo de nova palavra-passe *@
            <div class="form-group">
                <label asp-for="NewPassword">Nova Palavra-passe</label>
                <input asp-for="NewPassword" type="password" class="form-control" placeholder="••••••••" required />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            @* Campo de confirmação da nova palavra-passe *@
            <div class="form-group">
                <label asp-for="ConfirmPassword">Confirmar Nova Palavra-passe</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" required />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            @* Botão de submissão *@
            <button type="submit" class="btn-primary btn-block">Alterar Palavra-passe</button>
        </form>

        @* Link para voltar ao dashboard *@
        <div class="login-footer">
            <p><a href="@Url.Action("Dashboard", "Member")" class="forgot-password-link">Voltar ao Dashboard</a></p>
        </div>
    </div>
</div>

@* ============================================================================
   ESTILOS CSS ESPECÍFICOS DA PÁGINA
   ============================================================================ *@
<style>
/* Contentor principal com imagem de fundo */
.login-container {
    min-height: calc(100vh - 200px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    position: relative;
    overflow: hidden;
    background: var(--bg-primary);
    /* Imagem de fundo de ginásio */
    background-image: url('https://images.unsplash.com/photo-1534438327276-14e5300c3a48?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
}

/* Sobreposição escura para melhor legibilidade */
.login-container::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
        135deg,
        rgba(30, 31, 41, 0.85) 0%,
        rgba(30, 31, 41, 0.75) 50%,
        rgba(30, 31, 41, 0.85) 100%
    );
    z-index: 0;
}

/* Caixa do formulário com efeito de vidro */
.login-box {
    background: var(--bg-card);
    border-radius: 12px;
    padding: 3rem;
    width: 100%;
    max-width: 450px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
    position: relative;
    z-index: 1;
    backdrop-filter: blur(10px);
}

/* Cabeçalho centralizado */
.login-header {
    text-align: center;
    margin-bottom: 2rem;
}

/* Título com cor de destaque */
.login-header h1 {
    font-size: 3rem;
    color: var(--accent);
    margin-bottom: 0.5rem;
}

/* Subtítulo */
.login-header h2 {
    font-size: 1.5rem;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
}

/* Descrição */
.login-header p {
    color: var(--text-secondary);
    font-size: 0.9rem;
}

/* Formulário */
.login-form {
    margin-top: 2rem;
}

/* Grupo de campo */
.form-group {
    margin-bottom: 1.5rem;
}

/* Etiquetas */
.form-group label {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
    font-weight: 500;
}

/* Campos de input */
.form-control {
    width: 100%;
    padding: 0.75rem 1rem;
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text-primary);
    font-size: 1rem;
    transition: all 0.3s;
}

/* Estado de foco */
.form-control:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(2, 172, 195, 0.1);
}

/* Botão de largura total */
.btn-block {
    width: 100%;
    margin-top: 1rem;
}

/* Rodapé */
.login-footer {
    margin-top: 2rem;
    text-align: center;
    color: var(--text-secondary);
    font-size: 0.9rem;
}

/* Links */
.login-footer a {
    color: var(--accent);
    text-decoration: none;
}

/* Link de navegação */
.forgot-password-link {
    color: var(--text-secondary);
    text-decoration: underline;
    cursor: pointer;
    transition: color 0.3s ease;
}

.forgot-password-link:hover {
    color: var(--accent);
    text-decoration: underline;
}

/* Texto de erro */
.text-danger {
    color: var(--error);
    font-size: 0.875rem;
    margin-top: 0.25rem;
    display: block;
}

/* Estilos de alertas */
.alert {
    padding: 1rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
}

/* Alerta de aviso (amarelo) */
.alert-warning {
    background: rgba(255, 193, 7, 0.1);
    border: 1px solid rgba(255, 193, 7, 0.3);
    color: #ffc107;
}

/* Alerta de sucesso (verde) */
.alert-success {
    background: rgba(40, 167, 69, 0.1);
    border: 1px solid rgba(40, 167, 69, 0.3);
    color: #28a745;
}
</style>
